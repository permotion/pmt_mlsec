FROM python:3.11-slim
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir "mlflow>=2.12,<3.0" psycopg2-binary>=2.9
# Crear directorio de artefactos con permisos públicos para que Airflow (UID 50000) pueda escribir
RUN mkdir -p /opt/mlflow/artifacts && chmod 777 /opt/mlflow/artifacts
